APP_URL=http://localhost:3000
AUTH_SECRET=replace-with-a-long-random-secret

# Either DATABASE_URL or the MYSQL_* fields can be used.
DATABASE_URL=mysql://root:Giogio123@localhost:3306/biostar_status_ops

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=biostar_status_ops
MYSQL_USER=root
MYSQL_PASSWORD=Giogio123

# Optional BioStar2 integration placeholders.
# Supports either https://devices.tbilisikids.com or https://devices.tbilisikids.com/api/login.
BIOSTAR2_BASE_URL=https://devices.tbilisikids.com/api/login
BIOSTAR2_USERNAME=
BIOSTAR2_PASSWORD=
# Set to false only when the internal BioStar server has a certificate purpose error.
BIOSTAR2_TLS_REJECT_UNAUTHORIZED=true

# Optional: enables high quality static Google map image on the dashboard.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
